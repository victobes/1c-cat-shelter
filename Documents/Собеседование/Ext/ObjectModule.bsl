
Процедура ОбработкаЗаполнения(ДанныеЗаполнения, СтандартнаяОбработка)
	
	Если ТипЗнч(ДанныеЗаполнения) = Тип("ДокументСсылка.ЗаявкаНаУчастиеВСобеседовании") Тогда
		Кошка             = ДанныеЗаполнения.Кошка;
		Укотовитель       = ДанныеЗаполнения.Укотовитель;
		ДокументОснование = ДанныеЗаполнения.Ссылка;
	КонецЕсли;
	
КонецПроцедуры
